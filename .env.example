# Live mode: fetch real OpenWeather data in the dashboard (use for Streamlit Cloud)
LIVE_MODE=false

# Demo mode: static bundled sample_data/ (offline fallback only)
DEMO_MODE=false

# OpenWeatherMap API key — https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=weather_data
KAFKA_STARTING_OFFSETS=latest

# Slack incoming webhook (optional) — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Anomaly detection
ANOMALY_Z_THRESHOLD=2.5
BASELINE_DAYS=7
MIN_BASELINE_SAMPLES=5
ALERT_COOLDOWN_SECONDS=3600

# Streaming cadence
TRIGGER_INTERVAL=30 seconds
